<?xml version="1.0" encoding="UTF-8"?>
<PluginList>
    <Plugin id="DB Wave Player" name="DB Wave Player" category="DB Modules/Input-Output">
        <Audio>
            <Pin name="File Name" datatype="string" isFilename="true" metadata="wav"/>
            <Pin name="Gate" datatype="bool" default="1"/>
			<Pin name="Loop" datatype="bool" default="0"/>
            <Pin name="Output L" datatype="float" rate="audio" direction="out"/>
            <Pin name="Output R" datatype="float" rate="audio" direction="out"/>
        </Audio>
    </Plugin>
</PluginList>
